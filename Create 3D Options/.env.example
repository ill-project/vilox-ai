# ============================================================
# Vilox AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# NEVER add SUPABASE_SERVICE_ROLE_KEY here — it only belongs in Supabase Edge Function secrets

# ── Market Data ───────────────────────────────────────────────
# Binance WebSocket base URL (free, no key required)
VITE_BINANCE_WS_URL=wss://stream.binance.com:9443

# CoinGecko API key (optional — Pro key raises rate limits)
VITE_COINGECKO_API_KEY=

# AlphaVantage — free key from https://www.alphavantage.co/support/#api-key
# Used for real-time stock prices (GOOGL, NVDA, TSLA, AAPL, MSFT)
VITE_ALPHA_VANTAGE_KEY=

# ── Feature Flags ─────────────────────────────────────────────
# Set to "false" to disable WebSocket and fall back to polling
VITE_ENABLE_WEBSOCKET=true

# Set to "false" to disable Supabase Realtime subscriptions
VITE_ENABLE_REALTIME=true

# Always serve mock data as fallback when live feeds fail
VITE_MOCK_FALLBACK=true

# ── Trading ───────────────────────────────────────────────────
# Platform fee rate applied to all trades (0.001 = 0.1%)
VITE_APP_FEE_RATE=0.001

# ── Payments ─────────────────────────────────────────────────
# Stripe publishable key (pk_live_... for production)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_

# ── App ───────────────────────────────────────────────────────
VITE_APP_ENV=development
